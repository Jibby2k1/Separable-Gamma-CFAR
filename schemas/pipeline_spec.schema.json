{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Neurobench Pipeline Spec",
  "type": "object",
  "required": ["schema_version", "dataset_id", "run_id", "pipeline", "artifacts"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "dataset_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "label": {"type": "string"},
    "pipeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id"],
        "anyOf": [
          {"required": ["stage_id"]},
          {"required": ["stage"]},
          {"required": ["name"]}
        ],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "stage_id": {"type": "string", "minLength": 1},
          "stage": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "params": {"type": "object"},
          "metadata": {"type": "object"},
          "artifacts": {"type": "object"}
        },
        "additionalProperties": true
      }
    },
    "sweep": {
      "type": "object",
      "required": ["parameters"],
      "properties": {
        "id": {"type": "string"},
        "label": {"type": "string"},
        "parameters": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["stage", "param", "values"],
            "properties": {
              "stage": {"type": "string", "minLength": 1},
              "stage_id": {"type": "string", "minLength": 1},
              "param": {"type": "string", "minLength": 1},
              "values": {"type": "array", "minItems": 1}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "artifacts": {"type": "object"}
  },
  "additionalProperties": true
}
