{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Neurobench Pipeline Run",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "dataset_id",
    "pipeline_spec_id",
    "status",
    "created_at",
    "parameter_hash",
    "artifacts"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "dataset_id": {"type": "string", "minLength": 1},
    "pipeline_spec_id": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["planned", "running", "completed", "failed", "skipped"]},
    "created_at": {"type": "string", "minLength": 1},
    "completed_at": {"type": ["string", "null"]},
    "parameter_hash": {"type": "string", "minLength": 1},
    "environment": {"type": "object"},
    "code": {"type": "object"},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["schema_version", "artifact_id", "kind", "path", "producer_stage", "sha256"],
        "properties": {
          "schema_version": {"type": "integer", "const": 1},
          "artifact_id": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "schema": {"type": ["string", "null"]},
          "producer_stage": {"type": "string", "minLength": 1},
          "created_at": {"type": ["string", "null"]},
          "sha256": {"type": "string", "minLength": 1},
          "summary": {"type": "object"},
          "extras": {"type": "object"}
        },
        "additionalProperties": true
      }
    },
    "metrics": {"type": "object"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "logs": {"type": "array", "items": {"type": "string"}},
    "extras": {"type": "object"}
  },
  "additionalProperties": true
}
